rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || resource.data.referredBy == request.auth.uid || resource.data.uplineId == request.auth.uid);
      allow create: if request.auth != null; 
      allow update: if request.auth != null && request.auth.uid == userId 
        && !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['mainBalance', 'referralCommissionBalance', 'uplineId']);
    }
    
    match /user_packages/{pkgId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid 
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['miningStartTime']);
    }
    
    match /user_robots/{robotId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Only server can update/delete
    }
    
    match /mining_logs/{logId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Only server can write
    }
    
    match /commission_logs/{logId} {
      allow read: if request.auth != null && resource.data.toUser == request.auth.uid;
      allow write: if false; // Only server can write
    }
    
    match /transaction_logs/{logId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Only server can write
    }

    // --- Admins ---
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Packages & Configs ---
    match /packages/{docId} {
      allow read: if true; 
      allow write: if isSignedIn(); 
    }
    match /robots_config/{docId} {
      allow read: if true; 
      allow write: if isSignedIn();
    }
    match /config/{docId} {
      allow read: if true; 
      allow write: if isSignedIn();
    }
    match /admin/{docId} {
      allow read: if true; 
      allow write: if isSignedIn();
    }

    // --- Mining & Work ---
    match /mining_states/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /work_history/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Financials ---
    match /deposits/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /withdraws/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /transactions/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Support & Communication ---
    match /support/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /landing_chats/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /messages/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /chats/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Others ---
    match /notifications/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /tasks/{docId} {
      allow read: if true; 
      allow write: if isSignedIn();
    }
    match /homepage_tasks/{docId} {
      allow read: if true; 
      allow write: if isSignedIn();
    }
    match /completed_tasks/{docId} {
      allow read: if isSignedIn(); 
      allow write: if isSignedIn();
    }
    match /user_tasks/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /referral_earnings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /landing_support/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /support_chats/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
